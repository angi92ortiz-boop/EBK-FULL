-- Buscador de Billetera Virtual
local function ObtenerDinero()
    local stats = lp:FindFirstChild("leaderstats") or lp:FindFirstChild("Data")
    if stats then
        local cash = stats:FindFirstChild("Cash") or stats:FindFirstChild("Money") or stats:FindFirstChild("Dinero")
        if cash then return cash.Value end
    end
    return 0
end

