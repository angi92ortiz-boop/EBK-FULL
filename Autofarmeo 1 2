local function EscanearStaff(player)
    if player == lp then return end
    
    -- 1. Detección automática por ID de Creador (Usuario o Grupo)
    if game.CreatorType == Enum.CreatorType.User and player.UserId == game.CreatorId then
        lp:Kick("\n[KING'PARRA SHIELD]\nDueño del juego detectado en el servidor: " .. player.Name)
    elseif game.CreatorType == Enum.CreatorType.Group then
        pcall(function()
            -- Filtra rangos administrativos altos dentro del grupo creador del juego
            if player:GetRankInGroup(game.CreatorId) >= 10 then 
                lp:Kick("\n[KING'PARRA SHIELD]\nStaff del grupo oficial detectado: " .. player.Name)
            end
        end)
    end
    
    -- 2. Detección por patrones de texto en Nombre o DisplayName
    local nameLower = player.Name:lower()
    local displayLower = player.DisplayName:lower()
    if nameLower:find("admin") or nameLower:find("mod") or nameLower:find("staff") or nameLower:find("owner") or
       displayLower:find("admin") or displayLower:find("mod") or displayLower:find("staff") then
        lp:Kick("\n[KING'PARRA SHIELD]\nPosible Moderador detectado por nombre: " .. player.Name)
    end
end

-- Escaneo en tiempo real (Jugadores actuales y entrantes)
for _, p in pairs(playersService:GetPlayers()) do EscanearStaff(p) end
playersService.PlayerAdded:Connect(EscanearStaff)
