    local function EjecutarTeleportMoto(boton, vectorDestino, textoOriginal)
        local char = lp.Character
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        if hum and hum.Health > 0 then
            local seat = hum.SeatPart
            if seat and (seat:IsA("VehicleSeat") or seat:IsA("Seat")) then
                local vehiculo = seat.Parent
                if vehiculo:IsA("Model") then
                    if vehiculo.PrimaryPart then 
                        vehiculo:SetPrimaryPartCFrame(CFrame.new(vectorDestino)) 
                    else 
                        vehiculo:MoveTo(vectorDestino) 
                    end
                else
                    seat.CFrame = CFrame.new(vectorDestino)
                end
            else
                boton.Text = "¡SUBE A UNA MOTO!"
                boton.TextColor3 = MainRed
                task.wait(1.2)
                boton.Text = textoOriginal
                boton.TextColor3 = Color3.fromRGB(255, 255, 255)
            end
        end
    end

