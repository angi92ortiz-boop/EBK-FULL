-- // EBK BHUB - SECURE RAINBOW EDITION 👑 //
-- Key: BACK01
local CLAVE_CORRECTA = "BACK01"

local function ExecuteHub()
    local Players = game:GetService("Players")
    local RunService = game:GetService("RunService")
    local Lighting = game:GetService("Lighting")
    local HttpService = game:GetService("HttpService")
    local L_Plr = Players.LocalPlayer
    local Camera = workspace.CurrentCamera

    -- Variables para el sistema de restauración y contadores
    local objetosEliminadosLista = {}
    local contadorEliminados = 0
    local contadorRestaurados = 0
    
    -- Variables de estado seguras
    _G.SpeedHack = false

    -- // SEGURIDAD AVANZADA (ANTI-DETECCIÓN) //
    local ScreenGui = Instance.new("ScreenGui")
    pcall(function()
        if gethui then
            ScreenGui.Parent = gethui()
        elseif syn and syn.protect_gui then
            syn.protect_gui(ScreenGui)
            ScreenGui.Parent = game:GetService("CoreGui")
        else
            ScreenGui.Parent = game:GetService("CoreGui")
        end
    end)
    ScreenGui.Name = HttpService:GenerateGUID(false)

    -- // LÓGICA RAINBOW OPTIMIZADA //
    local function MakeRainbow(obj)
        task.spawn(function()
            while obj and obj.Parent and task.wait() do
                local hue = tick() % 5 / 5
                local color = Color3.fromHSV(hue, 1, 1)
                if obj:IsA("UIStroke") then 
                    obj.Color = color
                elseif obj:IsA("TextLabel") or obj:IsA("TextButton") then 
                    obj.TextColor3 = color
                end
            end
        end)
    end

    -- // BOTÓN DE RECUPERACIÓN //
    local OpenBtn = Instance.new("TextButton", ScreenGui)
    OpenBtn.Size = UDim2.new(0, 80, 0, 30); OpenBtn.Position = UDim2.new(0, 10, 0.5, 0)
    OpenBtn.BackgroundColor3 = Color3.fromRGB(10,10,10); OpenBtn.Text = "ABRIR"; OpenBtn.Visible = false
    OpenBtn.Font = Enum.Font.Code; OpenBtn.TextSize = 14; Instance.new("UICorner", OpenBtn)
    local OpenStroke = Instance.new("UIStroke", OpenBtn); MakeRainbow(OpenStroke); MakeRainbow(OpenBtn)

    -- // VENTANA DE KEY //
    local KeyFrame = Instance.new("Frame", ScreenGui)
    KeyFrame.Size = UDim2.new(0, 300, 0, 160); KeyFrame.Position = UDim2.new(0.5, -150, 0.5, -80)
    KeyFrame.BackgroundColor3 = Color3.fromRGB(10,10,10); KeyFrame.Active = true; KeyFrame.Draggable = true; Instance.new("UICorner", KeyFrame)
    local KeyStroke = Instance.new("UIStroke", KeyFrame); KeyStroke.Thickness = 2; MakeRainbow(KeyStroke)
    
    local KeyTitle = Instance.new("TextLabel", KeyFrame)
    KeyTitle.Size = UDim2.new(1, 0, 0, 40); KeyTitle.Text = "EBK HUB"; KeyTitle.BackgroundTransparency = 1; KeyTitle.Font = Enum.Font.Code; KeyTitle.TextSize = 18; MakeRainbow(KeyTitle)
    
    local KeyInput = Instance.new("TextBox", KeyFrame)
    KeyInput.Size = UDim2.new(0, 220, 0, 40); KeyInput.Position = UDim2.new(0.5, -110, 0.45, 0)
    KeyInput.PlaceholderText = "Ingrese Clave..."; KeyInput.Text = ""; KeyInput.BackgroundColor3 = Color3.fromRGB(20,20,20); KeyInput.TextColor3 = Color3.new(1,1,1); Instance.new("UICorner", KeyInput)
    
    local KeyBtn = Instance.new("TextButton", KeyFrame)
    KeyBtn.Size = UDim2.new(0, 120, 0, 35); KeyBtn.Position = UDim2.new(0.5, -60, 0.78, 0)
    KeyBtn.Text = "VALIDAR"; KeyBtn.BackgroundColor3 = Color3.fromRGB(0, 40, 0); MakeRainbow(KeyBtn); Instance.new("UICorner", KeyBtn)

    -- // VENTANA PRINCIPAL //
    local MainFrame = Instance.new("Frame", ScreenGui)
    MainFrame.Size = UDim2.new(0, 530, 0, 390); MainFrame.Position = UDim2.new(0.5, -265, 0.5, -190)
    MainFrame.BackgroundColor3 = Color3.fromRGB(10,10,10); MainFrame.Visible = false; MainFrame.Active = true; MainFrame.Draggable = true; Instance.new("UICorner", MainFrame)
    local MainStroke = Instance.new("UIStroke", MainFrame); MainStroke.Thickness = 2; MakeRainbow(MainStroke)
    
    KeyBtn.MouseButton1Click:Connect(function()
        if KeyInput.Text == CLAVE_CORRECTA then 
            KeyFrame.Visible = false; MainFrame.Visible = true
        else 
            KeyInput.Text = ""; KeyInput.PlaceholderText = "CLAVE INVÁLIDA" 
        end
    end)
    OpenBtn.MouseButton1Click:Connect(function() MainFrame.Visible = true; OpenBtn.Visible = false end)
    
    -- // CONFIGURACIÓN GLOBAL ESP //
    _G.ESP_Enabled = false
    _G.Visuals = { Box = false, Names = false, Dist = false, Weapon = false, HeadTracer = false, HealthBar = false }

    -- // PORTADA PERSONALIZADA CON USUARIO //
    local Banner = Instance.new("TextLabel", MainFrame)
    Banner.Size = UDim2.new(1, 0, 0, 45); 
    Banner.Text = "  BIENVENIDO A ACUSADO, " .. L_Plr.Name:upper() .. " 👑"
    Banner.BackgroundColor3 = Color3.fromRGB(20, 20, 20); Banner.Font = Enum.Font.Code; Banner.TextSize = 16; Banner.TextXAlignment = Enum.TextXAlignment.Left; Instance.new("UICorner", Banner); MakeRainbow(Banner)

    -- // ESP DRAWING LOGIC //
    local function CreateESP(plr)
        local Box = Drawing.new("Square"); Box.Thickness = 1; Box.Filled = false; Box.Color = Color3.new(1,1,1); Box.Visible = false
        local Name = Drawing.new("Text"); Name.Size = 13; Name.Center = true; Name.Outline = true; Name.Color = Color3.new(1,1,1); Name.Visible = false
        local Dist = Drawing.new("Text"); Dist.Size = 13; Dist.Center = true; Dist.Outline = true; Dist.Color = Color3.new(1,1,1); Dist.Visible = false
        local Weap = Drawing.new("Text"); Weap.Size = 13; Weap.Center = true; Weap.Outline = true; Weap.Color = Color3.new(1, 1, 1); Weap.Visible = false
        local HeadTracer = Drawing.new("Line"); HeadTracer.Thickness = 1.5; HeadTracer.Color = Color3.new(1,1,1); HeadTracer.Visible = false
        local HealthBar = Drawing.new("Square"); HealthBar.Thickness = 1; HealthBar.Filled = true; HealthBar.Visible = false

        local RenderConnection
        RenderConnection = RunService.RenderStepped:Connect(function()
            if not plr or not plr.Parent then
                Box:Destroy()
                Name:Destroy()
                Dist:Destroy()
                Weap:Destroy()
                HeadTracer:Destroy()
                HealthBar:Destroy()
                if RenderConnection then RenderConnection:Disconnect() end
                return
            end

            if plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") and plr.Character:FindFirstChild("Humanoid") and plr.Character.Humanoid.Health > 0 and plr ~= L_Plr then
                local HRP = plr.Character.HumanoidRootPart
                local Hum = plr.Character.Humanoid
                local Pos, OnScreen = Camera:WorldToViewportPoint(HRP.Position)

                if OnScreen then
                    local Size = (Camera:WorldToViewportPoint(HRP.Position - Vector3.new(0, 3, 0)).Y - Camera:WorldToViewportPoint(HRP.Position + Vector3.new(0, 2.6, 0)).Y)
                    local BoxSize = Vector2.new(Size / 1.5, Size)
                    local BoxPos = Vector2.new(Pos.X - BoxSize.X / 2, Pos.Y - BoxSize.Y / 2)
                    local rainbowColor = Color3.fromHSV(tick() % 5 / 5, 1, 1)

                    -- Cuadro (Box)
                    Box.Visible = _G.Visuals.Box; Box.Size = BoxSize; Box.Position = BoxPos; Box.Color = rainbowColor
                    
                    -- Nombre
                    Name.Visible = _G.Visuals.Names; Name.Text = plr.Name; Name.Position = Vector2.new(Pos.X, BoxPos.Y - 15); Name.Color = rainbowColor
                    
                    -- Distancia
                    local myChar = L_Plr.Character
                    if myChar and myChar:FindFirstChild("HumanoidRootPart") then
                        local d = math.floor((myChar.HumanoidRootPart.Position - HRP.Position).Magnitude)
                        Dist.Visible = _G.Visuals.Dist; Dist.Text = "["..d.."m]"; Dist.Position = Vector2.new(Pos.X, BoxPos.Y + BoxSize.Y + 5)
                    end
                    
                    -- Arma equipada
                    local tool = plr.Character:FindFirstChildOfClass("Tool")
                    Weap.Visible = _G.Visuals.Weapon; Weap.Text = tool and tool.Name or "Hands"; Weap.Position = Vector2.new(Pos.X, BoxPos.Y + BoxSize.Y + 18)
                    
                    -- Barra de Vida Dinámica
                    HealthBar.Visible = _G.Visuals.HealthBar; HealthBar.Size = Vector2.new(2, (Hum.Health / Hum.MaxHealth) * BoxSize.Y); HealthBar.Position = Vector2.new(BoxPos.X - 5, BoxPos.Y + (BoxSize.Y - HealthBar.Size.Y)); HealthBar.Color = Color3.fromHSV(Hum.Health/Hum.MaxHealth * 0.3, 1, 1)

                    -- Lógica del Tracer de Cabeza a Cabeza (AL MÁS CERCANO)
                    local closestPlayer = nil
                    local shortestDistance = math.huge
                    
                    if myChar and myChar:FindFirstChild("HumanoidRootPart") then
                        for _, p in pairs(Players:GetPlayers()) do
                            if p ~= L_Plr and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health > 0 then
                                local dist = (myChar.HumanoidRootPart.Position - p.Character.HumanoidRootPart.Position).Magnitude
                                if dist < shortestDistance then
                                    shortestDistance = dist
                                    closestPlayer = p
                                end
                            end
                        end
                    end
                    
                    if _G.Visuals.HeadTracer and closestPlayer == plr and myChar and myChar:FindFirstChild("Head") and plr.Character:FindFirstChild("Head") then
                        local myHeadPos = Camera:WorldToViewportPoint(myChar.Head.Position)
                        local tHeadPos = Camera:WorldToViewportPoint(plr.Character.Head.Position)
                        HeadTracer.From = Vector2.new(myHeadPos.X, myHeadPos.Y)
                        HeadTracer.To = Vector2.new(tHeadPos.X, tHeadPos.Y)
                        HeadTracer.Color = rainbowColor
                        HeadTracer.Visible = true
                    else
                        HeadTracer.Visible = false
                    end
                else
                    Box.Visible = false; Name.Visible = false; Dist.Visible = false; Weap.Visible = false; HeadTracer.Visible = false; HealthBar.Visible = false
                end
            else
                Box.Visible = false; Name.Visible = false; Dist.Visible = false; Weap.Visible = false; HeadTracer.Visible = false; HealthBar.Visible = false
            end
        end)
    end

    -- Inicialización del ESP
    for _, p in pairs(Players:GetPlayers()) do 
        if p ~= L_Plr then CreateESP(p) end 
    end
    Players.PlayerAdded:Connect(function(p)
        if p ~= L_Plr then CreateESP(p) end
    end)

    -- // CONTENEDORES //
    local Container = Instance.new("Frame", MainFrame)
    Container.Position = UDim2.new(0, 150, 0, 55); Container.Size = UDim2.new(1, -160, 1, -65); Container.BackgroundTransparency = 1
    local Tabs = { 
        Combat = Instance.new("ScrollingFrame"), 
        Visuals = Instance.new("ScrollingFrame"), 
        Misc = Instance.new("ScrollingFrame"),
        Teleport = Instance.new("ScrollingFrame")
    }
    
    for name, frame in pairs(Tabs) do
        frame.Size = UDim2.new(1, 0, 1, 0); frame.BackgroundTransparency = 1; frame.Visible = (name == "Combat"); frame.Parent = Container; frame.ScrollBarThickness = 0
        Instance.new("UIListLayout", frame).Padding = UDim.new(0, 10)
    end
    
    local function AddBtn(parent, text, func)
        local b = Instance.new("TextButton", parent); b.Size = UDim2.new(1, -10, 0, 40)
        b.BackgroundColor3 = Color3.fromRGB(30, 30, 30); b.Text = "[ " .. text .. " ]"; b.Font = Enum.Font.Code; b.TextSize = 14; Instance.new("UICorner", b)
        MakeRainbow(b)
        b.MouseButton1Click:Connect(function() pcall(func) end)
        return b
    end
    
    -- --- OPCIONES DE COMBATE ---
    AddBtn(Tabs.Combat, "CARGAR AIMBOT AURORA", function() loadstring(game:HttpGet("https://raw.githubusercontent.com/Aurora-Script/Script/refs/heads/main/ScriptSb"))() end)
    AddBtn(Tabs.Combat, "CARGAR EBK SFARM", function() loadstring(game:HttpGet("https://raw.githubusercontent.com/angi92ortiz-boop/EBK-FULL/main/Jj"))() end)
    
    -- --- OPCIONES DE VISUALES ---
    AddBtn(Tabs.Visuals, "ACTIVAR ESP FULL", function() 
        _G.ESP_Enabled = not _G.ESP_Enabled 
        _G.Visuals.Box = _G.ESP_Enabled
        _G.Visuals.Names = _G.ESP_Enabled
        _G.Visuals.Dist = _G.ESP_Enabled
        _G.Visuals.Weapon = _G.ESP_Enabled
        _G.Visuals.HealthBar = _G.ESP_Enabled
        _G.Visuals.HeadTracer = _G.ESP_Enabled
    end)

    -- --- OPCIONES MISCELÁNEAS (SISTEMA) ---
    AddBtn(Tabs.Misc, "OPTIMIZAR FPS", function() 
        Lighting.GlobalShadows = false
        for _, v in pairs(game:GetDescendants()) do 
            if v:IsA("Part") then v.Material = Enum.Material.SmoothPlastic 
            elseif v:IsA("Decal") then v:Destroy() end 
        end 
    end)

    -- FUNCIÓN: SPEED HACK CONFIGURADO A 23 (CON RESET A 16 AL APAGAR)
    local SpeedBtn = AddBtn(Tabs.Misc, "SPEED HACK : APAGADO", function()
        _G.SpeedHack = not _G.SpeedHack
    end)

    task.spawn(function()
        local cambioAplicado = false
        while task.wait() do
            pcall(function()
                if _G.SpeedHack then
                    cambioAplicado = true
                    SpeedBtn.Text = "[ SPEED HACK : PRENDIDO ]"
                    if L_Plr.Character and L_Plr.Character:FindFirstChild("Humanoid") then
                        L_Plr.Character.Humanoid.WalkSpeed = 23
                    end
                else
                    SpeedBtn.Text = "[ SPEED HACK : APAGADO ]"
                    if cambioAplicado then
                        cambioAplicado = false
                        if L_Plr.Character and L_Plr.Character:FindFirstChild("Humanoid") then
                            L_Plr.Character.Humanoid.WalkSpeed = 16 -- Devuelve la velocidad normal
                        end
                    end
                end
            end)
        end
    end)

    -- Etiquetas de contadores de objetos
    local LabelEliminados = Instance.new("TextLabel", Tabs.Misc)
    LabelEliminados.Size = UDim2.new(1, -10, 0, 25); LabelEliminados.BackgroundTransparency = 1
    LabelEliminados.Font = Enum.Font.Code; LabelEliminados.TextSize = 14; LabelEliminados.Text = "Objetos eliminados: " .. contadorEliminados
    MakeRainbow(LabelEliminados)

    local LabelRestaurados = Instance.new("TextLabel", Tabs.Misc)
    LabelRestaurados.Size = UDim2.new(1, -10, 0, 25); LabelRestaurados.BackgroundTransparency = 1
    LabelRestaurados.Font = Enum.Font.Code; LabelRestaurados.TextSize = 14; LabelRestaurados.Text = "Objetos restaurados: " .. contadorRestaurados
    MakeRainbow(LabelRestaurados)
    
    AddBtn(Tabs.Misc, "DELETE TOOL", function() 
        local t = Instance.new("Tool", L_Plr.Backpack); t.Name = "DEL_TOOL"; t.RequiresHandle = false
        t.Activated:Connect(function() 
            local target = L_Plr:GetMouse().Target 
            if target and not target.Parent:FindFirstChild("Humanoid") then 
                table.insert(objetosEliminadosLista, {Instancia = target, PadreOriginal = target.Parent})
                target.Parent = nil 
                
                contadorEliminados = contadorEliminados + 1
                LabelEliminados.Text = "Objetos eliminados: " .. contadorEliminados
            end 
        end) 
    end)

    -- BOTÓN DE RESTAURACIÓN DE A UN SÓLO OBJETO POR CLICK
    AddBtn(Tabs.Misc, "RESTAURAR OBJETOS", function()
        if #objetosEliminadosLista > 0 then
            local infoObjeto = table.remove(objetosEliminadosLista)
            if infoObjeto and infoObjeto.Instancia and infoObjeto.PadreOriginal then
                infoObjeto.Instancia.Parent = infoObjeto.PadreOriginal
                
                contadorRestaurados = contadorRestaurados + 1
                LabelRestaurados.Text = "Objetos restaurados: " .. contadorRestaurados
            end
        end
    end)

    -- --- LÓGICA DE TELEPORT (MOTO) ---
    local TpMessage = Instance.new("TextLabel", Tabs.Teleport)
    TpMessage.Size = UDim2.new(1, -10, 0, 30); TpMessage.BackgroundTransparency = 1
    TpMessage.Text = "⚠️ SOLO SE PUEDE USAR EN MOTO ⚠️"; TpMessage.Font = Enum.Font.Code; TpMessage.TextSize = 14
    MakeRainbow(TpMessage)

    local locations = {
        {"Conprar/vender🍬", Vector3.new(519.27, 3.59, 606.96)},
        {"Consecionario🚘", Vector3.new(741.76, 3.71, 433.77)},
        {"Armeria 1️⃣", Vector3.new(217.39, 3.74, -174.63)},
        {"Armeria 2️⃣", Vector3.new(-463.24, 3.86, 358.16)},
        {"Tienda casino☘️", Vector3.new(1016.60, 3.61, -327.68)},
        {"Casino☘️", Vector3.new(1213.34, 3.36, -47.72)},
        {"Verder Arma🔫", Vector3.new(85.18, 3.76, 38.44)},
        {"Depa hospi 1️⃣", Vector3.new(1140.63, 10.11, 421.04)},
        {"Depa Tier 1️⃣", Vector3.new(985.76, 10.11, 248.31)},
        {"Depa 3️⃣", Vector3.new(925.26, 10.11, 40.25)},
        {"Depa 4️⃣", Vector3.new(896.53, 10.11, 41.55)},
        {"Fabrica 🥔", Vector3.new(-473.69, 3.86, -460.23)},
        {"Tienda de 🥔", Vector3.new(-769.51, 3.66, -179.22)},
    }

    for _, locData in ipairs(locations) do
        local locName = locData[1]
        local locPos = locData[2]
        
        AddBtn(Tabs.Teleport, "TP: " .. locName, function()
            local char = L_Plr.Character
            if char then
                local hum = char:FindFirstChild("Humanoid")
                if hum and hum.Sit and hum.SeatPart then
                    local vehicle = hum.SeatPart:FindFirstAncestorOfClass("Model")
                    if vehicle and vehicle ~= char then
                        vehicle:PivotTo(CFrame.new(locPos + Vector3.new(0, 3, 0)))
                    else
                        hum.SeatPart.CFrame = CFrame.new(locPos + Vector3.new(0, 3, 0))
                    end
                end
            end
        end)
    end

    -- --- NAVEGACIÓN ---
    local Sidebar = Instance.new("Frame", MainFrame); Sidebar.Size = UDim2.new(0, 140, 1, -55); Sidebar.Position = UDim2.new(0, 5, 0, 50); Sidebar.BackgroundTransparency = 1
    local function AddTab(txt, target, y)
        local b = Instance.new("TextButton", Sidebar); b.Size = UDim2.new(1, -10, 0, 45); b.Position = UDim2.new(0, 5, 0, y)
        b.BackgroundColor3 = Color3.fromRGB(20, 20, 20); b.Text = txt; b.Font = Enum.Font.Code; Instance.new("UICorner", b)
        MakeRainbow(b)
        b.MouseButton1Click:Connect(function() for _, t in pairs(Tabs) do t.Visible = false end; Tabs[target].Visible = true end)
    end
    
    AddTab("COMBATE", "Combat", 0)
    AddTab("VISUALES", "Visuals", 55)
    AddTab("SISTEMA", "Misc", 110)
    AddTab("TELEPORT", "Teleport", 165)
    
    local CloseBtn = Instance.new("TextButton", MainFrame); CloseBtn.Size = UDim2.new(0, 30, 0, 30); CloseBtn.Position = UDim2.new(1, -38, 0, 8); CloseBtn.Text = "X"; CloseBtn.BackgroundColor3 = Color3.fromRGB(50,0,0); CloseBtn.TextColor3 = Color3.new(1,1,1); Instance.new("UICorner", CloseBtn)
    CloseBtn.MouseButton1Click:Connect(function() MainFrame.Visible = false; OpenBtn.Visible = true end)
end

pcall(ExecuteHub)
